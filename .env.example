APP_NAME="Tinhouse Engineering"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tinhouse
DB_USERNAME=tinhouse
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tinhouse.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=tinhouse
AWS_ENDPOINT=http://minio:9000
AWS_URL=http://localhost:9000/tinhouse
AWS_USE_PATH_STYLE_ENDPOINT=true

APP_PORT=8080
VITE_FORWARD_PORT=5173
DB_FORWARD_PORT=5432
REDIS_FORWARD_PORT=6379
MINIO_FORWARD_PORT=9000
MINIO_CONSOLE_FORWARD_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MAILPIT_FORWARD_PORT=8025
ADMINER_FORWARD_PORT=8081

PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
BROWSERSHOT_CHROME_PATH=/usr/bin/chromium
BROWSERSHOT_NODE_BINARY=/usr/bin/node
DOCUMENT_PDF_RENDERER=chromium
DOCUMENT_PDF_DISPOSITION=inline
FEATURE_PROGRESS_PHOTOS=false

ATTENDANCE_REQUIRE_PHOTO=false
ATTENDANCE_ALLOWED_DISTANCE_METERS=250
ATTENDANCE_ALLOW_MANUAL_CORRECTION=false
COMPANY_NAME="鐵皮屋工程管理系統"
COMPANY_PHONE=
COMPANY_ADDRESS=
COMPANY_TAX_ID=
QUOTATION_DEFAULT_TERMS=
PAYMENT_BANK_NAME=
PAYMENT_BANK_CODE=
PAYMENT_ACCOUNT_NUMBER=
PAYMENT_ACCOUNT_NAME=
INVOICE_DEFAULT_TERMS=
INVENTORY_DEFAULT_SAFE_STOCK=0

VITE_APP_NAME="${APP_NAME}"
